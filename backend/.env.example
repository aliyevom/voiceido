# Copy to .env and fill in values.
# GCP service account JSON path (Vision + Speech-to-Text must be enabled).
GCP_CREDENTIALS_PATH=/path/to/your-service-account.json
GCP_PROJECT_ID=your-gcp-project-id

# OpenRouter (for Analyze and Video summary).
OPENROUTER_API_KEY=

# Optional
PORT=4000
UPLOAD_DIR=./uploads
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
MAX_TIMELINE_CHARS=80000
